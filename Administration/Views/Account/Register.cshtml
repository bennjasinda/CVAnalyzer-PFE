@model Administration.ViewModels.RegisterViewModel
@{
    Layout = "_LoginLayout";
    ViewData["Title"] = "Inscription";
}

<div class="card p-4">
    <h2 class="text-center mb-2">Inscription</h2>
    <p class="text-center text-muted">Créez votre compte</p>

    <form method="post">

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <!-- Username -->
        <div class="mb-3">
            <label class="form-label">Nom Utilisateur</label>
            <input asp-for="NomUtilisateur" class="form-control" placeholder="Nom utilisateur">
            <span asp-validation-for="NomUtilisateur" class="text-danger small"></span>
        </div>

        <!-- Email -->
        <div class="mb-3">
            <label class="form-label">Email</label>
            <input asp-for="Email" class="form-control" placeholder="Email">
            <span asp-validation-for="Email" class="text-danger small"></span>
        </div>

        <!-- Password -->
        <div class="mb-3">
            <label class="form-label">Mot de passe</label>
            <input asp-for="MotPasse" type="password" class="form-control" placeholder="Mot de passe">
            <span asp-validation-for="MotPasse" class="text-danger small"></span>
            <div class="form-text">
                Le mot de passe doit contenir :
                <ul class="mb-0 mt-1">
                    <li>Au moins 8 caract&egrave;res</li>
                    <li>Une lettre majuscule (A-Z)</li>
                    <li>Une lettre minuscule (a-z)</li>
                    <li>Un chiffre (0-9)</li>
                    <li>Un caract&egrave;re sp&eacute;cial (&#64;, #, $, etc.)</li>
                </ul>
            </div>
        </div>

        <!-- Confirm Password -->
        <div class="mb-3">
            <label class="form-label">Confirmer mot de passe</label>
            <input asp-for="ConfirmMotPasse" type="password" class="form-control" placeholder="Confirmer">
            <span asp-validation-for="ConfirmMotPasse" class="text-danger small"></span>
        </div>

        <!-- Role -->
        <div class="mb-3">
            <label class="form-label">Rôle</label>
            <select asp-for="Role" class="form-control">
                <option value="">-- Choisir --</option>
                <option value="Candidat">Candidat</option>
                <option value="RH">RH</option>
                <option value="Directeur">Directeur</option>
                <option value="Admin">Admin</option>
            </select>
        </div>

        <!-- Button -->
        <button type="submit" class="btn btn-success w-100">S'inscrire</button>

        <!-- Link -->
        <div class="mt-3 text-center">
            Vous avez déjà un compte ? <a asp-action="Login">Connectez-vous</a>
        </div>

    </form>
</div>